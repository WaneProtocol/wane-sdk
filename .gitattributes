# normalize line endings across platforms
* text=auto eol=lf

*.ts    text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary

# linguist: keep generated declarations out of the language bar
dist/*              linguist-generated
docs/*              linguist-documentation
